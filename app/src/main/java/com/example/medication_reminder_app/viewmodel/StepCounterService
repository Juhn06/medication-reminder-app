package com.example.medication_reminder_app;

import android.app.Notification;
import android.app.NotificationChannel;
import android.app.NotificationManager;
import android.app.Service;
import android.content.Context;
import android.content.Intent;
import android.content.SharedPreferences;
import android.hardware.Sensor;
import android.hardware.SensorEvent;
import android.hardware.SensorEventListener;
import android.hardware.SensorManager;
import android.os.Build;
import android.os.IBinder;

import androidx.core.app.NotificationCompat;

import java.text.SimpleDateFormat;
import java.util.Date;
import java.util.Locale;

public class StepCounterService extends Service implements SensorEventListener {

    private SensorManager sensorManager;
    private SharedPreferences prefs;
    private long baseSteps = 0;

    @Override
    public void onCreate() {
        super.onCreate();
        // Khi dịch vụ khởi tạo: Chuẩn bị biến lưu trữ và bật Cảm biến
        prefs = getSharedPreferences("StepPrefs", MODE_PRIVATE);
        baseSteps = prefs.getLong("base_steps", 0);

        sensorManager = (SensorManager) getSystemService(Context.SENSOR_SERVICE);
        if (sensorManager != null) {
            Sensor stepSensor = sensorManager.getDefaultSensor(Sensor.TYPE_STEP_COUNTER);
            sensorManager.registerListener(this, stepSensor, SensorManager.SENSOR_DELAY_NORMAL);
        }
    }

    @Override
    public int onStartCommand(Intent intent, int flags, int startId) {
        // Ép Service lên Foreground với thông báo "im lặng"
        createQuietNotificationChannel();
        Notification notification = new NotificationCompat.Builder(this, "QuietChannel")
                .setContentTitle("Bộ đếm bước chân")
                .setContentText("Đang theo dõi bước đi...")
                //.setSmallIcon(R.drawable.ic_step) // Mở comment và thay icon của bạn vào đây
                .setPriority(NotificationCompat.PRIORITY_MIN)
                .setOngoing(true)
                .build();

        startForeground(1, notification);

        // START_STICKY giúp Service tự khởi động lại nếu bị hệ thống vô tình kill
        return START_STICKY;
    }

    @Override
    public IBinder onBind(Intent intent) {
        return null;
    }

    @Override
    public void onDestroy() {
        super.onDestroy();
        // 4. Dọn dẹp trước khi kết thúc: Tắt lắng nghe cảm biến để tiết kiệm pin
        if (sensorManager != null) {
            sensorManager.unregisterListener(this);
        }
    }
    @Override
    public void onSensorChanged(SensorEvent event) {
        if (event.sensor.getType() == Sensor.TYPE_STEP_COUNTER) {
            long totalHardwareSteps = (long) event.values[0];

            String today = new SimpleDateFormat("yyyy-MM-dd", Locale.getDefault()).format(new Date());
            String lastDate = prefs.getString("last_date", "");

            // Xử lý qua ngày mới hoặc máy vừa khởi động lại
            if (!today.equals(lastDate) || totalHardwareSteps < baseSteps) {
                baseSteps = totalHardwareSteps;
                prefs.edit().putLong("base_steps", baseSteps).putString("last_date", today).apply();
            }

            int todaySteps = (int) (totalHardwareSteps - baseSteps);

            // Gửi dữ liệu về Activity
            Intent broadcastIntent = new Intent("STEP_UPDATE");
            broadcastIntent.putExtra("steps", todaySteps);
            sendBroadcast(broadcastIntent);
        }
    }

    @Override
    public void onAccuracyChanged(Sensor sensor, int accuracy) {
    }
    private void createQuietNotificationChannel() {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            NotificationChannel channel = new NotificationChannel(
                    "QuietChannel", "Chạy ngầm", NotificationManager.IMPORTANCE_MIN);
            channel.setShowBadge(false);

            NotificationManager manager = getSystemService(NotificationManager.class);
            if (manager != null) manager.createNotificationChannel(channel);
        }
    }
}
